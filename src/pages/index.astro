---
// src/pages/index.astro
import { getCollection } from "astro:content";
import Footer from "../components/Footer.astro";
import Navbar from "../components/Navbar.astro";
import SmartEduCTA from "../components/SmartEduCTA.astro";
import Layout from "../layouts/Layout.astro";
import { slugify } from "../utils/slugify";

// Pobierz ostatnie posty
const allPosts = await getCollection("blog", ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true;
});

const recentPosts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("pl-PL", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
};

// Schema.org
const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "@id": "https://www.licencjackie.pl/#website",
  name: "Licencjackie.pl",
  alternateName: "Licencjackie",
  description:
    "Wszystko o pisaniu prac dyplomowych. Poradniki, tematy prac, metodologia badań.",
  url: "https://www.licencjackie.pl/",
  inLanguage: "pl-PL",
  publisher: { "@id": "https://www.licencjackie.pl/#organization" },
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "@id": "https://www.licencjackie.pl/#organization",
  name: "Licencjackie.pl",
  url: "https://www.licencjackie.pl/",
  logo: {
    "@type": "ImageObject",
    url: "https://www.licencjackie.pl/logo.png",
    width: 512,
    height: 512,
  },
  description:
    "Portal edukacyjny dla studentów piszących prace licencjackie i magisterskie. Poradniki, tematy prac dyplomowych, metodologia badań naukowych.",
};

// Pełna lista kierunków (identyczna jak na /kierunki)
const kierunki = [
  { name: "Administracja", slug: "pisanie-prac-z-administracji", icon: "🏛️" },
  { name: "Bezpieczeństwo wewnętrzne", slug: "pisanie-prac-z-bezpieczenstwa-wewnetrznego", icon: "🛡️" },
  { name: "Dietetyka", slug: "pisanie-prac-z-dietetyki", icon: "🥗" },
  { name: "Geografia", slug: "pisanie-prac-z-geografii", icon: "🌍" },
  { name: "Historia", slug: "pisanie-prac-z-historii", icon: "📜" },
  { name: "Kosmetologia", slug: "pisanie-prac-z-kosmetologii", icon: "💄" },
  { name: "Kryminologia", slug: "pisanie-prac-z-kryminologii", icon: "🔍" },
  { name: "Logistyka", slug: "pisanie-prac-z-logistyki", icon: "📦" },
  { name: "Marketing", slug: "pisanie-prac-z-marketingu", icon: "📈" },
  { name: "Pedagogika", slug: "pisanie-prac-z-pedagogiki", icon: "👨‍🏫" },
  { name: "Pielęgniarstwo", slug: "pisanie-prac-z-pielegniarstwa", icon: "🏥" },
  { name: "Politologia", slug: "pisanie-prac-z-politologii", icon: "🗳️" },
  { name: "Prawo", slug: "pisanie-prac-z-prawa", icon: "⚖️" },
  { name: "Psychologia", slug: "pisanie-prac-z-psychologii", icon: "🧠" },
  { name: "Ratownictwo medyczne", slug: "pisanie-prac-z-ratownictwa-medycznego", icon: "🚑" },
  { name: "Socjologia", slug: "pisanie-prac-z-socjologii", icon: "👥" },
  { name: "Turystyka", slug: "pisanie-prac-z-turystyki", icon: "✈️" },
  { name: "Zarządzanie", slug: "pisanie-prac-z-zarzadzania", icon: "💼" },
];
---

<Layout
  title="Pisanie pracy licencjackiej i magisterskiej - jak napisać pracę dyplomową? | Licencjackie.pl"
  description="Poradniki, tematy prac, metodologia badań. Profesjonalna pomoc w pisaniu prac licencjackich i magisterskich."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(websiteSchema)}
    slot="head"
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(organizationSchema)}
    slot="head"
  />

  <Navbar />

  <main>
    <!-- Hero Section -->
    <section
      class="pt-28 pb-20 bg-gradient-to-br from-primary-50 via-white to-accent/10"
    >
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="max-w-3xl mx-auto text-center">
          <h1
            class="text-4xl sm:text-5xl lg:text-6xl font-bold text-gray-900 mb-6 leading-tight"
          >
            Wszystko o pisaniu
            <span class="text-gradient"> prac dyplomowych</span>
          </h1>
          <p class="text-xl text-gray-600 mb-10 leading-relaxed">
            Poradniki, tematy prac, metodologia badań i profesjonalna pomoc w
            pisaniu prac licencjackich i magisterskich.
          </p>

          <div
            class="flex flex-col sm:flex-row items-center justify-center gap-4"
          >
            <a
              href="/ebook/"
              class="w-full sm:w-auto px-8 py-4 bg-gradient-to-r from-primary-600 to-accent text-white font-semibold rounded-xl hover:opacity-90 transition-opacity inline-flex items-center justify-center gap-2"
            >
              📘 Ebook: jak napisać pracę licencjacką
              <span class="bg-white/25 text-white text-sm font-bold px-2 py-0.5 rounded">29 zł</span>
            </a>
            <a
              href="https://smart-edu.ai"
              target="_blank"
              rel="sponsored noopener noreferrer"
              class="w-full sm:w-auto px-8 py-4 border-2 border-gray-300 text-gray-700 font-semibold rounded-xl hover:border-primary-500 hover:text-primary-600 transition-colors"
            >
              Napisz pracę z AI →
            </a>
          </div>
          <p class="mt-5 text-sm text-gray-500">
            Zacznij od przewodnika: <a href="/pisanie-prac-licencjackich/" class="text-primary-600 font-medium hover:underline">pisanie prac licencjackich</a>,
            <a href="/pisanie-prac-dyplomowych/" class="text-primary-600 font-medium hover:underline">pisanie prac dyplomowych</a>,
            pobierz <a href="/przykladowe-prace/" class="text-primary-600 font-medium hover:underline">przykładową pracę licencjacką (25 wzorów PDF)</a>
            albo <a href="/blog/" class="text-primary-600 font-medium hover:underline">przeglądaj darmowe poradniki</a>
          </p>
        </div>
      </div>
    </section>

    <!-- Smart-Edu CTA -->
    <section class="py-12 bg-white">
      <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
        <SmartEduCTA variant="full" />
      </div>
    </section>

    <!-- Tematy prac - NOWA SEKCJA -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
          Tematy prac dyplomowych
        </h2>
        <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
          Gotowe propozycje tematów na prace licencjackie i magisterskie z różnych kierunków
        </p>

        <div class="grid md:grid-cols-2 gap-6 max-w-4xl mx-auto">
          <a
            href="/blog/kategoria/tematy-prac-licencjackich/"
            class="group block bg-gradient-to-br from-primary-50 to-white border-2 border-primary-200 rounded-2xl p-8 hover:border-primary-500 hover:shadow-xl transition-all"
          >
            <div class="text-5xl mb-4">🎓</div>
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-primary-600 transition-colors mb-3">
              Tematy prac licencjackich
            </h3>
            <p class="text-gray-600 mb-4">
              Setki sprawdzonych tematów na prace licencjackie i inżynierskie z 25 kierunków studiów.
            </p>
            <span class="text-primary-600 font-semibold">
              Przeglądaj tematy →
            </span>
          </a>

          <a
            href="/blog/kategoria/tematy-prac-magisterskich/"
            class="group block bg-gradient-to-br from-accent/10 to-white border-2 border-accent/30 rounded-2xl p-8 hover:border-accent hover:shadow-xl transition-all"
          >
            <div class="text-5xl mb-4">📚</div>
            <h3 class="text-2xl font-bold text-gray-900 group-hover:text-accent-dark transition-colors mb-3">
              Tematy prac magisterskich
            </h3>
            <p class="text-gray-600 mb-4">
              Zaawansowane tematy badawcze na prace magisterskie dla studentów II stopnia.
            </p>
            <span class="text-accent-dark font-semibold">
              Przeglądaj tematy →
            </span>
          </a>
        </div>
      </div>
    </section>

    <!-- Categories - Kierunki studiów -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-4">
          Wybierz swój kierunek studiów
        </h2>
        <p class="text-gray-600 text-center mb-10 max-w-2xl mx-auto">
          Znajdź poradniki, tematy prac i materiały dopasowane do Twojego kierunku
        </p>

        <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-4">
          {
            kierunki.map((kierunek) => (
              <a
                href={`/blog/kategoria/${kierunek.slug}/`}
                class="p-4 bg-white border border-gray-200 rounded-xl hover:border-primary-500 hover:shadow-lg transition-all text-center group"
              >
                <span class="text-2xl mb-2 block">{kierunek.icon}</span>
                <span class="font-medium text-sm text-gray-900 group-hover:text-primary-600 transition-colors">
                  {kierunek.name}
                </span>
              </a>
            ))
          }
        </div>

        <div class="text-center mt-8">
          <a
            href="/kierunki"
            class="inline-flex items-center gap-2 text-primary-600 font-medium hover:underline"
          >
            Zobacz wszystkie kierunki →
          </a>
        </div>
      </div>
    </section>

    <!-- Recent Posts -->
    <section class="py-16 bg-white">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between mb-10">
          <h2 class="text-3xl font-bold text-gray-900">Najnowsze poradniki</h2>
          <a
            href="/blog"
            class="text-primary-600 font-medium hover:underline hidden sm:block"
          >
            Zobacz wszystkie →
          </a>
        </div>

        {
          recentPosts.length === 0 ? (
            <div class="text-center py-12 bg-gray-50 rounded-2xl">
              <p class="text-gray-500">Artykuły pojawią się tutaj wkrótce.</p>
            </div>
          ) : (
            <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
              {recentPosts.map((post) => (
                <a
                  href={`/blog/${post.slug}/`}
                  class="group block bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-500 hover:shadow-lg transition-all"
                >
                  {post.data.image ? (
                    <div class="aspect-video bg-gray-100 overflow-hidden">
                      <picture>
                        <source srcset={post.data.image.replace(/\.jpe?g$/i, ".webp")} type="image/webp" />
                        <img
                          src={post.data.image}
                          alt={post.data.imageAlt || post.data.title}
                          width="1200"
                          height="630"
                          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                          loading="lazy"
                          decoding="async"
                        />
                      </picture>
                    </div>
                  ) : (
                    <div class="aspect-video bg-gradient-to-br from-primary-100 to-accent/20 flex items-center justify-center">
                      <span class="text-4xl font-bold text-primary-300">
                        {post.data.title.substring(0, 2).toUpperCase()}
                      </span>
                    </div>
                  )}
                  <div class="p-5">
                    <div class="flex items-center gap-2 mb-3">
                      <span class="px-2 py-0.5 text-xs font-medium bg-primary-100 text-primary-700 rounded">
                        {post.data.category}
                      </span>
                      <span class="text-xs text-gray-500">
                        {formatDate(post.data.publishDate)}
                      </span>
                    </div>
                    <h3 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
                      {post.data.title}
                    </h3>
                    <p class="text-sm text-gray-600 line-clamp-2">
                      {post.data.description}
                    </p>
                  </div>
                </a>
              ))}
            </div>
          )
        }
      </div>
    </section>

    <!-- Features -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl font-bold text-gray-900 text-center mb-12">
          Dlaczego Licencjackie.pl?
        </h2>

        <div class="grid md:grid-cols-3 gap-8">
          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-2xl flex items-center justify-center"
            >
              <svg
                class="w-8 h-8 text-primary-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"
                ></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">
              Sprawdzone poradniki
            </h3>
            <p class="text-gray-600">
              Materiały przygotowane przez ekspertów z wieloletnim
              doświadczeniem akademickim
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 bg-accent/20 rounded-2xl flex items-center justify-center"
            >
              <svg
                class="w-8 h-8 text-accent-dark"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">
              Gotowe tematy prac
            </h3>
            <p class="text-gray-600">
              Setki sprawdzonych tematów z różnych kierunków studiów gotowych do
              wykorzystania
            </p>
          </div>

          <div class="text-center">
            <div
              class="w-16 h-16 mx-auto mb-4 bg-primary-100 rounded-2xl flex items-center justify-center"
            >
              <svg
                class="w-8 h-8 text-primary-600"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 mb-2">Pomoc AI</h3>
            <p class="text-gray-600">
              Skorzystaj ze Smart-Edu.ai i wygeneruj profesjonalną pracę
              dyplomową w kilka godzin
            </p>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>