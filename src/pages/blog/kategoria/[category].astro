---
// src/pages/blog/kategoria/[category].astro
import { getCollection, type CollectionEntry } from "astro:content";
import Footer from "../../../components/Footer.astro";
import Navbar from "../../../components/Navbar.astro";
import SmartEduCTA from "../../../components/SmartEduCTA.astro";
import Layout from "../../../layouts/Layout.astro";
import { slugify } from "../../../utils/slugify";
import { categoryIntros } from "../../../data/category-intros";

type BlogCategory = CollectionEntry<"blog">["data"]["category"];

interface Props {
  categoryName: BlogCategory;
  posts: CollectionEntry<"blog">[];
}

export async function getStaticPaths() {
  const posts = await getCollection("blog");

  // WSZYSTKIE KATEGORIE - musi być WEWNĄTRZ getStaticPaths
  const ALL_CATEGORIES = [
    "Poradniki",
    "Struktura pracy",
    "Metodologia",
    "Tematy prac licencjackich",
    "Tematy prac magisterskich",
    "Obrona pracy",
    "Pisanie prac z pedagogiki",
    "Pisanie prac z psychologii",
    "Pisanie prac z prawa",
    "Pisanie prac z administracji",
    "Pisanie prac z historii",
    "Pisanie prac z pielęgniarstwa",
    "Pisanie prac z zarządzania",
    "Pisanie prac z marketingu",
    "Pisanie prac z logistyki",
    "Pisanie prac z socjologii",
    "Pisanie prac z kryminologii",
    "Pisanie prac z turystyki",
    "Pisanie prac z kosmetologii",
    "Pisanie prac z dietetyki",
    "Pisanie prac z ratownictwa medycznego",
    "Pisanie prac z politologii",
    "Pisanie prac z geografii",
    "Pisanie prac z bezpieczeństwa wewnętrznego",
  ];

  return ALL_CATEGORIES.map((category) => ({
    params: { category: slugify(category) },
    props: {
      categoryName: category,
      posts: posts
        .filter((post) => post.data.category === category)
        .sort(
          (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
        ),
    },
  }));
}

const { categoryName, posts } = Astro.props;

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("pl-PL", {
    year: "numeric",
    month: "short",
    day: "numeric",
  }).format(date);
};

const getReadingTime = (content: string) => {
  const words = content.split(/\s+/).length;
  return Math.ceil(words / 200);
};

const categoryDescriptions: Record<string, string> = {
  Poradniki: "Kompleksowe poradniki o pisaniu prac dyplomowych.",
  "Struktura pracy":
    "Jak poprawnie zbudować strukturę pracy licencjackiej i magisterskiej.",
  Metodologia:
    "Metody badawcze, ankiety, wywiady i analiza danych w pracach naukowych.",
  "Tematy prac licencjackich":
    "Propozycje tematów na prace licencjackie z różnych kierunków.",
  "Tematy prac magisterskich": "Propozycje tematów na prace magisterskie.",
  "Obrona pracy": "Przygotowanie do obrony pracy dyplomowej.",
  "Pisanie prac z pedagogiki": "Tematy i poradniki dla studentów pedagogiki.",
  "Pisanie prac z psychologii": "Tematy i poradniki dla studentów psychologii.",
  "Pisanie prac z prawa": "Tematy i poradniki dla studentów prawa.",
  "Pisanie prac z administracji":
    "Tematy i poradniki dla studentów administracji.",
  "Pisanie prac z historii": "Tematy i poradniki dla studentów historii.",
  "Pisanie prac z pielęgniarstwa":
    "Tematy i poradniki dla studentów pielęgniarstwa.",
  "Pisanie prac z zarządzania": "Tematy i poradniki dla studentów zarządzania.",
  "Pisanie prac z marketingu": "Tematy i poradniki dla studentów marketingu.",
  "Pisanie prac z logistyki": "Tematy i poradniki dla studentów logistyki.",
  "Pisanie prac z socjologii": "Tematy i poradniki dla studentów socjologii.",
  "Pisanie prac z kryminologii":
    "Tematy i poradniki dla studentów kryminologii.",
  "Pisanie prac z turystyki": "Tematy i poradniki dla studentów turystyki.",
  "Pisanie prac z kosmetologii":
    "Tematy i poradniki dla studentów kosmetologii.",
  "Pisanie prac z dietetyki": "Tematy i poradniki dla studentów dietetyki.",
  "Pisanie prac z ratownictwa medycznego":
    "Tematy i poradniki dla studentów ratownictwa medycznego.",
  "Pisanie prac z politologii": "Tematy i poradniki dla studentów politologii.",
  "Pisanie prac z geografii": "Tematy i poradniki dla studentów geografii.",
  "Pisanie prac z bezpieczeństwa wewnętrznego":
    "Tematy i poradniki dla studentów bezpieczeństwa wewnętrznego.",
};

const getPageTitle = (cat: string) => {
  if (cat.startsWith("Pisanie prac z")) {
    const kierunek = cat.replace("Pisanie prac z ", "");
    return `Pisanie prac dyplomowych z ${kierunek}`;
  }
  return cat;
};

const categorySlug = slugify(categoryName);
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    {
      "@type": "ListItem",
      position: 1,
      name: "Strona główna",
      item: "https://www.licencjackie.pl/",
    },
    {
      "@type": "ListItem",
      position: 2,
      name: "Blog",
      item: "https://www.licencjackie.pl/blog/",
    },
    {
      "@type": "ListItem",
      position: 3,
      name: getPageTitle(categoryName),
      item: `https://www.licencjackie.pl/blog/kategoria/${categorySlug}/`,
    },
  ],
};

const collectionSchema = {
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  name: getPageTitle(categoryName),
  description:
    categoryDescriptions[categoryName] || `Artykuły z kategorii ${categoryName}`,
  url: `https://www.licencjackie.pl/blog/kategoria/${categorySlug}/`,
  isPartOf: {
    "@type": "WebSite",
    name: "Licencjackie.pl",
    url: "https://www.licencjackie.pl/",
  },
};
---

<Layout
  title={`${getPageTitle(categoryName)} | Licencjackie.pl`}
  description={categoryDescriptions[categoryName] ||
    `Artykuły z kategorii ${categoryName}`}
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(breadcrumbSchema)}
    slot="head"
  />
  <script
    type="application/ld+json"
    set:html={JSON.stringify(collectionSchema)}
    slot="head"
  />
  <Navbar />

  <main class="pt-32 pb-20">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <nav class="mb-8" aria-label="Breadcrumb">
        <ol class="flex items-center gap-2 text-sm text-gray-500">
          <li><a href="/" class="hover:text-primary-600">Strona główna</a></li>
          <li>/</li>
          <li><a href="/blog/" class="hover:text-primary-600">Blog</a></li>
          <li>/</li>
          <li class="text-gray-900">{categoryName}</li>
        </ol>
      </nav>

      <header class="mb-12">
        <span
          class="inline-block px-4 py-2 bg-primary-100 text-primary-700 rounded-full text-sm font-medium mb-4"
        >
          Kategoria
        </span>
        <h1 class="text-4xl sm:text-5xl font-bold text-gray-900 mb-4">
          {categoryName.startsWith("Pisanie prac z") 
            ? `Pisanie prac dyplomowych z ${categoryName.replace("Pisanie prac z ", "")}`
            : categoryName}
        </h1>
        <p class="text-lg text-gray-600 max-w-2xl">
          {
            categoryDescriptions[categoryName] ||
              `Wszystkie artykuły z kategorii ${categoryName}`
          }
        </p>
        <div class="mt-4 text-sm text-gray-500">
          {posts.length}
          {
            posts.length === 1
              ? "artykuł"
              : posts.length < 5
                ? "artykuły"
                : "artykułów"
          }
        </div>
      </header>

      {
        categoryIntros[categoryName] && (
          <section
            class="prose prose-lg max-w-3xl mx-auto mb-12 text-gray-700"
            set:html={categoryIntros[categoryName]}
          />
        )
      }

      <div class="mb-12">
        <SmartEduCTA variant="inline" />
      </div>

      {
        posts.length === 0 ? (
          <div class="text-center py-16 bg-gray-50 rounded-2xl">
            <div class="text-6xl mb-4">📚</div>
            <p class="text-gray-600 text-lg mb-2">
              Artykuły z tej kategorii są w przygotowaniu.
            </p>
            <p class="text-gray-500 mb-6">
              Wkrótce dodamy treści dotyczące: {categoryName}
            </p>
            <a
              href="/blog/"
              class="inline-flex items-center gap-2 px-6 py-3 bg-primary-600 text-white rounded-xl hover:bg-primary-700 transition-colors"
            >
              ← Zobacz dostępne artykuły
            </a>
          </div>
        ) : (
          <div class={`grid gap-6 ${
            categoryName.startsWith("Pisanie prac z") 
              ? "sm:grid-cols-2 max-w-4xl mx-auto" 
              : "sm:grid-cols-2 lg:grid-cols-3"
          }`}>
            {posts.map((post) => (
              <a
                href={`/blog/${post.slug}/`}
                class="group block bg-white border border-gray-200 rounded-xl overflow-hidden hover:border-primary-500 hover:shadow-lg transition-all"
              >
                {post.data.image ? (
                  <div class="aspect-video bg-gray-100 overflow-hidden">
                    <picture>
                      <source srcset={post.data.image.replace(/\.jpe?g$/i, ".webp")} type="image/webp" />
                      <img
                        src={post.data.image}
                        alt={post.data.imageAlt || post.data.title}
                        width="1200"
                        height="630"
                        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
                        loading="lazy"
                        decoding="async"
                      />
                    </picture>
                  </div>
                ) : (
                  <div class="aspect-video bg-gradient-to-br from-primary-100 to-accent/20 flex items-center justify-center">
                    <span class="text-4xl font-bold text-primary-300">
                      {post.data.title.substring(0, 2).toUpperCase()}
                    </span>
                  </div>
                )}
                <div class="p-5">
                  <div class="text-xs text-gray-500 mb-3">
                    {formatDate(post.data.publishDate)}
                  </div>
                  <h2 class="text-lg font-bold text-gray-900 mb-2 group-hover:text-primary-600 transition-colors line-clamp-2">
                    {post.data.title}
                  </h2>
                  <p class="text-sm text-gray-600 line-clamp-2 mb-3">
                    {post.data.description}
                  </p>
                  <div class="flex items-center justify-between text-sm">
                    <span class="text-gray-500">
                      {getReadingTime(post.body || "")} min
                    </span>
                    <span class="text-primary-600 font-medium">→</span>
                  </div>
                </div>
              </a>
            ))}
          </div>
        )
      }

      <div class="mt-12 text-center">
        <a
          href="/blog/"
          class="inline-flex items-center gap-2 text-primary-600 hover:underline"
        >
          ← Wszystkie artykuły
        </a>
      </div>
    </div>
  </main>

  <Footer />
</Layout>

<style>
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>