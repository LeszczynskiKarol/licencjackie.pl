---
// src/pages/ebook/anulowano.astro
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import Layout from "../../layouts/Layout.astro";
---

<Layout
  title="Płatność anulowana - Licencjackie.pl"
  description="Płatność została anulowana."
  robots="noindex, nofollow"
>
  <Navbar />

  <main class="min-h-screen bg-gray-50 flex items-center justify-center py-24">
    <div class="max-w-lg mx-auto px-4 text-center">
      <div class="bg-white rounded-2xl shadow-xl p-8 md:p-12">
        <div class="w-20 h-20 bg-amber-100 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-10 h-10 text-amber-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
        </div>

        <h1 class="text-3xl font-bold text-gray-900 mb-4">Płatność anulowana</h1>
        <p class="text-gray-600 mb-8">Nic nie zostało pobrane z Twojego konta. Możesz spróbować ponownie w dowolnej chwili.</p>

        <div class="space-y-4">
          <a href="/ebook/" class="block w-full bg-primary-600 hover:bg-primary-700 text-white font-semibold py-3 px-6 rounded-xl transition-colors">Wróć do ebooka</a>
          <a href="/" class="block w-full bg-gray-100 hover:bg-gray-200 text-gray-700 font-semibold py-3 px-6 rounded-xl transition-colors">Strona główna</a>
        </div>
      </div>
    </div>
  </main>

  <Footer />
</Layout>
