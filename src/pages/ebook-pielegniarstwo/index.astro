---
// src/pages/ebook-pielegniarstwo/index.astro
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import Layout from "../../layouts/Layout.astro";

const API_URL = "https://kiv8tougqc.execute-api.eu-central-1.amazonaws.com/prod";

const PRODUCT_ID = "ebook-licencjacka-pielegniarstwo";

const ebook = {
  name: "Jak napisać pracę licencjacką z pielęgniarstwa",
  subtitle: "Od studium przypadku do obrony — praktyczny przewodnik",
  price: 29,
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: ebook.name,
  description:
    "Przewodnik PDF+EPUB pisania pracy licencjackiej z pielęgniarstwa: studium indywidualnego przypadku, proces pielęgnowania, skale kliniczne, styl Vancouver, etyka badań z pacjentem, obrona.",
  brand: { "@type": "Brand", name: "Licencjackie.pl" },
  offers: {
    "@type": "Offer",
    price: ebook.price,
    priceCurrency: "PLN",
    availability: "https://schema.org/InStock",
    url: "https://www.licencjackie.pl/ebook-pielegniarstwo/",
  },
};

const highlights = [
  { t: "Wywiad pielęgniarski: 16 elementów opisu", d: "Kompletny szkielet wywiadu, który musi znaleźć się w opisie przypadku — punkt po punkcie." },
  { t: "Skale kliniczne w praktyce", d: "Barthel (ADL 0–100), VAS i NRS, Norton, GCS — kiedy której użyć i jak zapisać wynik w pracy." },
  { t: "6 gotowych diagnoz pielęgniarskich", d: "Struktura diagnozy + sześć przykładów do adaptacji we własnym przypadku." },
  { t: "Plan opieki z ewaluacją", d: "Cele, interwencje, realizacja i ewaluacja — z przykładowym planem dla pacjenta z POChP." },
  { t: "Wymogi uczelni z realnych wytycznych", d: "Objętość, piśmiennictwo, marginesy, harmonogram konsultacji — zestawione z opublikowanych wytycznych uczelni medycznych." },
  { t: "Styl Vancouver bez błędów", d: "Cytowanie numeryczne, minimum 30 pozycji, wzory zapisu bibliograficznego artykułu i książki." },
  { t: "Etyka badań z pacjentem", d: "Zgoda pacjenta, anonimizacja, granica dokumentacji medycznej — co wolno, a czego nie." },
  { t: "Finisz: JSA i obrona", d: "Streszczenie strukturalne PL/EN, antyplagiat, harmonogram ostatniego miesiąca i pytania komisji." },
];
---

<Layout
  title="Ebook: Jak napisać pracę licencjacką z pielęgniarstwa (PDF + EPUB) | Licencjackie.pl"
  description="Przewodnik pisania pracy licencjackiej z pielęgniarstwa: studium przypadku, proces pielęgnowania, skale Barthel/VAS/Norton, styl Vancouver, etyka, obrona. PDF + EPUB za 29 zł."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
    slot="head"
  />

  <Navbar />

  <main class="min-h-screen">
    <!-- HERO -->
    <section class="pt-28 pb-16 bg-gradient-to-br from-emerald-50 via-white to-primary-50">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <div class="flex flex-wrap gap-2 mb-5">
              <span class="bg-emerald-100 text-emerald-800 px-3 py-1 rounded-full text-sm font-medium">🩺 Pielęgniarstwo</span>
              <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">PDF + EPUB</span>
              <span class="bg-gradient-to-r from-emerald-500 to-primary-500 text-white px-3 py-1 rounded-full text-sm font-medium">✨ Nowość 2026</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4 leading-tight">
              Jak napisać pracę licencjacką z pielęgniarstwa
            </h1>
            <p class="text-lg text-gray-600 mb-6">
              {ebook.subtitle}. Zero ogólników o „pracach dyplomowych" — wyłącznie
              warsztat pielęgniarski: opis przypadku, proces pielęgnowania, skale,
              Vancouver i obrona.
            </p>
            <div class="flex items-center gap-4 mb-6">
              <span class="text-4xl font-bold text-gray-900">{ebook.price} zł</span>
              <span class="text-sm text-gray-500">jednorazowo • PDF + EPUB • dostęp natychmiast</span>
            </div>
            <button
              data-product-id={PRODUCT_ID}
              class="buy-button w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-emerald-600 to-primary-600 text-white font-bold text-lg rounded-xl hover:opacity-90 transition-opacity"
            >
              📥 Kup przewodnik za {ebook.price} zł
            </button>
            <p class="text-xs text-gray-500 mt-3">Płatność: BLIK, karta, Revolut Pay (Stripe). Po opłaceniu paczka ZIP (PDF + EPUB) od razu na ekranie i mailem.</p>
          </div>
          <div class="text-center">
            <div class="inline-block bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
              <span class="text-8xl">🩺</span>
              <div class="mt-4 text-sm text-gray-500">Przewodnik kierunkowy · PDF + EPUB</div>
              <div class="mt-1 text-xs text-gray-400">czytaj na komputerze, tablecie i czytniku</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CO W ŚRODKU -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-3">Co znajdziesz w środku?</h2>
        <p class="text-center text-gray-600 mb-12">Warsztat pracy kazuistycznej krok po kroku — z przykładami gotowymi do adaptacji</p>
        <div class="grid md:grid-cols-2 gap-5">
          {highlights.map((c, i) => (
            <div class="flex gap-4 p-5 rounded-xl border border-gray-100 bg-gray-50">
              <span class="w-8 h-8 flex-shrink-0 bg-emerald-600 text-white rounded-full flex items-center justify-center text-sm font-bold">{i + 1}</span>
              <div>
                <h3 class="font-bold text-gray-900">{c.t}</h3>
                <p class="text-sm text-gray-600">{c.d}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <div class="inline-block bg-emerald-50 border border-emerald-200 rounded-xl px-6 py-4">
            <p class="text-emerald-800 text-sm">
              <strong>W każdym rozdziale:</strong> ramki z definicjami i pułapkami,
              przykłady z praktyki oddziałowej oraz checklisty do odhaczenia przed
              oddaniem rozdziału promotorowi.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- DLA KOGO -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Ten przewodnik jest dla Ciebie, jeśli:</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">📋</div>
            <h3 class="font-bold text-gray-900 mb-2">Piszesz studium przypadku</h3>
            <p class="text-sm text-gray-600">Dostajesz kompletny szkielet: wywiad, skale, diagnozy, plan opieki, ewaluacja — z przykładami.</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">🧾</div>
            <h3 class="font-bold text-gray-900 mb-2">Boisz się formalności</h3>
            <p class="text-sm text-gray-600">Vancouver, streszczenie strukturalne, zgody i etyka — wyjaśnione tak, żeby promotor nie miał uwag.</p>
          </div>
          <div class="bg-white rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">⏰</div>
            <h3 class="font-bold text-gray-900 mb-2">Goni Cię termin</h3>
            <p class="text-sm text-gray-600">Harmonogram ostatniego miesiąca i checklisty pozwalają domknąć pracę bez paniki.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 bg-white">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Najczęstsze pytania</h2>
        <div class="space-y-4">
          <details class="bg-gray-50 rounded-xl p-6 group" open>
            <summary class="font-semibold text-gray-900 cursor-pointer">W jakim formacie dostanę ebook?</summary>
            <p class="mt-3 text-gray-600 text-sm">W paczce ZIP z dwoma plikami: <strong>PDF</strong> (na komputer, tablet, do druku) i <strong>EPUB</strong> (na czytniki i aplikacje mobilne).</p>
          </details>
          <details class="bg-gray-50 rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">Jak szybko dostanę pliki?</summary>
            <p class="mt-3 text-gray-600 text-sm"><strong>Natychmiast</strong> — link do pobrania pojawia się na ekranie zaraz po płatności, a kopia trafia na e‑mail.</p>
          </details>
          <details class="bg-gray-50 rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">Czym różni się od ogólnego poradnika pisania prac?</summary>
            <p class="mt-3 text-gray-600 text-sm">Wszystkim, co pielęgniarskie: proces pielęgnowania, skale kliniczne, diagnozy, wymogi uczelni medycznych i styl Vancouver. <a href="/ebook/" class="text-primary-600 underline">Ogólny poradnik</a> uczy pisania prac w ogóle; ten — pracy z pielęgniarstwa.</p>
          </details>
          <details class="bg-gray-50 rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">Piszę pracę magisterską z pielęgniarstwa — co wtedy?</summary>
            <p class="mt-3 text-gray-600 text-sm">Sięgnij po wersję magisterską na siostrzanym serwisie: <a href="https://www.praca-magisterska.pl/tematy/pielegniarstwo/" class="text-primary-600 underline">praca-magisterska.pl</a> — badania własne, skale AIS/WHOQOL i statystyka.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-16 bg-gradient-to-r from-emerald-600 to-primary-600 text-white">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">Napisz licencjat, którego nie trzeba poprawiać</h2>
        <p class="text-lg text-white/90 mb-8">Kompletny warsztat pracy kazuistycznej z pielęgniarstwa — w PDF i EPUB.</p>
        <button
          data-product-id={PRODUCT_ID}
          class="buy-button inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-emerald-700 font-bold text-lg rounded-xl hover:bg-gray-50 transition-colors"
        >
          📥 Kup przewodnik za {ebook.price} zł
        </button>
        <p class="text-white/80 text-sm mt-4">Płatność jednorazowa • Dostęp natychmiast • PDF + EPUB na zawsze</p>
      </div>
    </section>
  </main>

  <!-- Loading overlay -->
  <div id="loading-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl p-8 text-center">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-emerald-600 mx-auto mb-4"></div>
      <p class="text-gray-700">Przekierowuję do płatności...</p>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ API_URL, PRODUCT_ID }}>
  // cSpell:ignore gtag
  document.addEventListener("DOMContentLoaded", function () {
    var PRODUCTS = {
      "ebook-licencjacka-pielegniarstwo": { name: "Jak napisać pracę licencjacką z pielęgniarstwa", price: 29.0 },
    };
    var buttons = document.querySelectorAll(".buy-button");
    var loadingOverlay = document.getElementById("loading-overlay");

    buttons.forEach(function (button) {
      button.addEventListener("click", async function () {
        var productId = button.dataset.productId || PRODUCT_ID;
        var product = PRODUCTS[productId] || { name: "Ebook", price: 0 };

        if (typeof window.gtag === "function") {
          var gaItem = { item_id: productId, item_name: product.name, price: product.price, quantity: 1, item_category: "Ebook" };
          window.gtag("event", "add_to_cart", { value: product.price, currency: "PLN", items: [gaItem] });
          window.gtag("event", "begin_checkout", { value: product.price, currency: "PLN", items: [gaItem] });
        }

        loadingOverlay.classList.remove("hidden");
        button.disabled = true;

        try {
          var response = await fetch(API_URL + "/create-checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId: productId }),
          });
          var data = await response.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            throw new Error(data.error || "Błąd");
          }
        } catch (error) {
          console.error("Error:", error);
          loadingOverlay.classList.add("hidden");
          button.disabled = false;
          alert("Wystąpił błąd. Spróbuj ponownie.");
        }
      });
    });
  });
</script>
