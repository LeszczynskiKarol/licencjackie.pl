---
// src/pages/ebook-marketing/index.astro
import Footer from "../../components/Footer.astro";
import Navbar from "../../components/Navbar.astro";
import Layout from "../../layouts/Layout.astro";

const API_URL = "https://kiv8tougqc.execute-api.eu-central-1.amazonaws.com/prod";

const PRODUCT_ID = "ebook-licencjacka-marketing";

const PREVIEW_PDF_URL =
  "https://praca-magisterska-ebooks.s3.eu-central-1.amazonaws.com/jak-napisac-prace-licencjacka-z-marketingu-preview.pdf";

const ebook = {
  name: "Jak napisać pracę licencjacką z marketingu",
  subtitle: "Od problemu do obrony — kompletny przewodnik",
  price: 49,
};

const productSchema = {
  "@context": "https://schema.org",
  "@type": "Product",
  name: ebook.name,
  description:
    "Przewodnik PDF+EPUB pisania pracy licencjackiej z marketingu: badanie konsumenckie, kwestionariusz i próba, analiza marki, media społecznościowe, rekomendacje, obrona.",
  brand: { "@type": "Brand", name: "Licencjackie.pl" },
  offers: {
    "@type": "Offer",
    price: ebook.price,
    priceCurrency: "PLN",
    availability: "https://schema.org/InStock",
    url: "https://www.licencjackie.pl/ebook-marketing/",
  },
};

const highlights = [
  { t: "Konstrukty i model badania", d: "Intencja zakupowa, lojalność, wizerunek — definicje, gotowe skale z literatury, hipotezy z uzasadnieniem." },
  { t: "Kwestionariusz bez ośmiu grzechów", d: "Architektura ankiety, redakcja pytań, pilotaż i budżet 8–12 minut." },
  { t: "Próba na miarę licencjatu", d: "Dobór, 80–120 respondentów, lejek i granice wniosków — bez słowa „reprezentatywna” na wyrost." },
  { t: "Analiza marki bez laurki", d: "Źródła, rama analityczna, ocena z dowodami i konfrontacja z odbiorcami." },
  { t: "Media społecznościowe z rygorem", d: "Korpus, klucz kodowy, metryki zaangażowania liczone uczciwie." },
  { t: "Analiza danych", d: "Alfa Cronbacha, mapa testów, werdykty hipotez — bez sprawozdania „pytanie po pytaniu”." },
  { t: "Korelacja to nie wpływ", d: "Język wniosków pod kontrolą — rozróżnienie, które komisje egzekwują zawsze." },
  { t: "Rekomendacje i obrona", d: "Rekomendacje z adresatem i rodowodem oraz kanon pytań komisji." },
];
---

<Layout
  title="Ebook: Jak napisać pracę licencjacką z marketingu (PDF + EPUB) | Licencjackie.pl"
  description="Przewodnik pisania pracy licencjackiej z finansów i rachunkowości: sprawozdania, analiza wskaźnikowa, interpretacja, synteza oceny, obrona. PDF + EPUB za 49 zł."
>
  <script
    type="application/ld+json"
    set:html={JSON.stringify(productSchema)}
    slot="head"
  />

  <Navbar />

  <main class="min-h-screen">
    <!-- HERO -->
    <section class="pt-28 pb-16 bg-gradient-to-br from-rose-50 via-white to-primary-50">
      <div class="max-w-5xl mx-auto px-4">
        <div class="grid md:grid-cols-2 gap-10 items-center">
          <div>
            <div class="flex flex-wrap gap-2 mb-5">
              <span class="bg-rose-100 text-rose-800 px-3 py-1 rounded-full text-sm font-medium">📣 Marketing</span>
              <span class="bg-gray-100 text-gray-700 px-3 py-1 rounded-full text-sm">PDF + EPUB</span>
              <span class="bg-gradient-to-r from-rose-500 to-primary-500 text-white px-3 py-1 rounded-full text-sm font-medium">✨ Nowość 2026</span>
            </div>
            <h1 class="text-4xl lg:text-5xl font-bold text-gray-900 mb-4 leading-tight">
              Jak napisać pracę licencjacką z marketingu
            </h1>
            <p class="text-lg text-gray-600 mb-6">
              {ebook.subtitle}. Zero ogólników o „pracach dyplomowych” — wyłącznie warsztat marketingowy: ankieta konsumencka z rygorem, analiza marki bez laurki i wnioski, które się bronią.
            </p>
            <div class="flex items-center gap-4 mb-6">
              <span class="text-4xl font-bold text-gray-900">{ebook.price} zł</span>
              <span class="text-sm text-gray-500">jednorazowo • PDF + EPUB • dostęp natychmiast</span>
            </div>
            <button
              data-product-id={PRODUCT_ID}
              class="buy-button w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-rose-600 to-primary-600 text-white font-bold text-lg rounded-xl hover:opacity-90 transition-opacity"
            >
              📥 Kup przewodnik za {ebook.price} zł
            </button>
            <p class="text-xs text-gray-500 mt-3">Płatność: BLIK, karta, Revolut Pay (Stripe). Po opłaceniu paczka ZIP (PDF + EPUB) od razu na ekranie i mailem.</p>
          </div>
          <div class="text-center">
            <div class="inline-block bg-white rounded-2xl shadow-xl border border-gray-100 p-8">
              <span class="text-8xl">📣</span>
              <div class="mt-4 text-sm text-gray-500">Przewodnik kierunkowy · PDF + EPUB</div>
              <div class="mt-1 text-xs text-gray-400">czytaj na komputerze, tablecie i czytniku</div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CO W ŚRODKU -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-3">Co znajdziesz w środku?</h2>
        <p class="text-center text-gray-600 mb-12">16 rozdziałów warsztatu analizy finansowej — z wzorcami interpretacji gotowymi do adaptacji</p>
        <div class="grid md:grid-cols-2 gap-5">
          {highlights.map((c, i) => (
            <div class="flex gap-4 p-5 rounded-xl border border-gray-100 bg-gray-50">
              <span class="w-8 h-8 flex-shrink-0 bg-rose-600 text-white rounded-full flex items-center justify-center text-sm font-bold">{i + 1}</span>
              <div>
                <h3 class="font-bold text-gray-900">{c.t}</h3>
                <p class="text-sm text-gray-600">{c.d}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="mt-10 text-center">
          <div class="inline-block bg-rose-50 border border-rose-200 rounded-xl px-6 py-4">
            <p class="text-rose-800 text-sm">
              <strong>W każdym rozdziale:</strong> ramki z definicjami i pułapkami,
              wzorcowe akapity interpretacji oraz checklisty do odhaczenia przed
              oddaniem rozdziału promotorowi.
            </p>
          </div>
        </div>
      </div>
    </section>

    <!-- PREVIEW -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-5xl mx-auto px-4">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-bold text-gray-900 mb-3">📖 Zajrzyj do środka</h2>
          <p class="text-gray-600">Okładka, pełny spis treści i cały pierwszy rozdział — za darmo.</p>
        </div>
        <div class="bg-white rounded-2xl shadow-xl overflow-hidden border border-gray-100">
          <div class="bg-rose-700 px-6 py-3 flex items-center justify-between">
            <div class="flex items-center gap-3">
              <div class="flex gap-1.5">
                <div class="w-3 h-3 rounded-full bg-red-400"></div>
                <div class="w-3 h-3 rounded-full bg-yellow-400"></div>
                <div class="w-3 h-3 rounded-full bg-green-400"></div>
              </div>
              <span class="text-sm text-rose-100">Fragment przewodnika — spis treści i rozdział 1</span>
            </div>
            <a href={PREVIEW_PDF_URL} target="_blank" class="text-sm text-white/90 hover:text-white">Otwórz w nowej karcie ↗</a>
          </div>
          <iframe src={PREVIEW_PDF_URL} class="w-full h-[600px] md:h-[700px] border-0" title="Preview przewodnika — finanse i rachunkowość"></iframe>
        </div>
        <div class="text-center mt-8">
          <button
            data-product-id={PRODUCT_ID}
            class="buy-button inline-flex items-center justify-center gap-2 px-8 py-4 bg-gradient-to-r from-rose-600 to-primary-600 text-white font-bold text-lg rounded-xl hover:opacity-90 transition-opacity"
          >
            📥 Kup pełny przewodnik za {ebook.price} zł
          </button>
        </div>
      </div>
    </section>

    <!-- DLA KOGO -->
    <section class="py-16 bg-white">
      <div class="max-w-5xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Ten przewodnik jest dla Ciebie, jeśli:</h2>
        <div class="grid md:grid-cols-3 gap-6">
          <div class="bg-gray-50 rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">📋</div>
            <h3 class="font-bold text-gray-900 mb-2">Boisz się ankiety „na kolanie”</h3>
            <p class="text-sm text-gray-600">Dostajesz warsztat kwestionariusza: skale z literatury, pilotaż, macierz pytanie → hipoteza.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">🏷️</div>
            <h3 class="font-bold text-gray-900 mb-2">Piszesz o marce</h3>
            <p class="text-sm text-gray-600">Analiza zamiast folderu: dane, rama, ocena — plus badanie odbiorców jako mocna konstrukcja.</p>
          </div>
          <div class="bg-gray-50 rounded-xl p-6 text-center shadow-sm">
            <div class="text-4xl mb-3">⏰</div>
            <h3 class="font-bold text-gray-900 mb-2">Goni Cię termin</h3>
            <p class="text-sm text-gray-600">Harmonogram ostatniego miesiąca i przejścia kontrolne domykają pracę bez paniki.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- FAQ -->
    <section class="py-16 bg-gray-50">
      <div class="max-w-3xl mx-auto px-4">
        <h2 class="text-3xl font-bold text-center text-gray-900 mb-12">Najczęstsze pytania</h2>
        <div class="space-y-4">
          <details class="bg-white rounded-xl p-6 group" open>
            <summary class="font-semibold text-gray-900 cursor-pointer">Czy przewodnik pomoże przy pracy o konkretnej marce lub kampanii?</summary>
            <p class="mt-3 text-gray-600 text-sm">Tak — osobne rozdziały opisują analizę marki (źródła, rama, ocena) i badanie mediów społecznościowych, a konstrukcja „case marki + badanie odbiorców” jest rozpisana krok po kroku.</p>
          </details>
          <details class="bg-white rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">W jakim formacie dostanę ebook?</summary>
            <p class="mt-3 text-gray-600 text-sm">W paczce ZIP z dwoma plikami: <strong>PDF</strong> (na komputer, tablet, do druku) i <strong>EPUB</strong> (na czytniki i aplikacje mobilne).</p>
          </details>
          <details class="bg-white rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">Jak szybko dostanę pliki?</summary>
            <p class="mt-3 text-gray-600 text-sm"><strong>Natychmiast</strong> — link do pobrania pojawia się na ekranie zaraz po płatności, a kopia trafia na e‑mail.</p>
          </details>
          <details class="bg-white rounded-xl p-6 group">
            <summary class="font-semibold text-gray-900 cursor-pointer">Piszę pracę magisterską z finansów — co wtedy?</summary>
            <p class="mt-3 text-gray-600 text-sm">Sięgnij po wersję magisterską na siostrzanym serwisie: <a href="https://www.praca-magisterska.pl/sklep/jak-napisac-prace-magisterska-z-marketingu/" class="text-primary-600 underline">praca-magisterska.pl</a> — większa próba, eksperyment i pełna statystyka.</p>
          </details>
        </div>
      </div>
    </section>

    <!-- FINAL CTA -->
    <section class="py-16 bg-gradient-to-r from-rose-600 to-primary-600 text-white">
      <div class="max-w-3xl mx-auto px-4 text-center">
        <h2 class="text-3xl font-bold mb-4 text-white">Napisz licencjat, którego nie trzeba poprawiać</h2>
        <p class="text-lg text-white/90 mb-8">Kompletny warsztat badania marketingowego — w PDF i EPUB.</p>
        <button
          data-product-id={PRODUCT_ID}
          class="buy-button inline-flex items-center justify-center gap-2 px-8 py-4 bg-white text-rose-700 font-bold text-lg rounded-xl hover:bg-gray-50 transition-colors"
        >
          📥 Kup przewodnik za {ebook.price} zł
        </button>
        <p class="text-white/80 text-sm mt-4">Płatność jednorazowa • Dostęp natychmiast • PDF + EPUB na zawsze</p>
      </div>
    </section>
  </main>

  <!-- Loading overlay -->
  <div id="loading-overlay" class="hidden fixed inset-0 bg-black/50 z-50 flex items-center justify-center">
    <div class="bg-white rounded-2xl p-8 text-center">
      <div class="animate-spin rounded-full h-12 w-12 border-b-2 border-rose-600 mx-auto mb-4"></div>
      <p class="text-gray-700">Przekierowuję do płatności...</p>
    </div>
  </div>

  <Footer />
</Layout>

<script define:vars={{ API_URL, PRODUCT_ID }}>
  // cSpell:ignore gtag
  document.addEventListener("DOMContentLoaded", function () {
    var PRODUCTS = {
      "ebook-licencjacka-marketing": { name: "Jak napisać pracę licencjacką z marketingu", price: 49.0 },
    };
    var buttons = document.querySelectorAll(".buy-button");
    var loadingOverlay = document.getElementById("loading-overlay");

    buttons.forEach(function (button) {
      button.addEventListener("click", async function () {
        var productId = button.dataset.productId || PRODUCT_ID;
        var product = PRODUCTS[productId] || { name: "Ebook", price: 0 };

        if (typeof window.gtag === "function") {
          var gaItem = { item_id: productId, item_name: product.name, price: product.price, quantity: 1, item_category: "Ebook" };
          window.gtag("event", "add_to_cart", { value: product.price, currency: "PLN", items: [gaItem] });
          window.gtag("event", "begin_checkout", { value: product.price, currency: "PLN", items: [gaItem] });
        }

        loadingOverlay.classList.remove("hidden");
        button.disabled = true;

        try {
          var response = await fetch(API_URL + "/create-checkout", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({ productId: productId }),
          });
          var data = await response.json();
          if (data.url) {
            window.location.href = data.url;
          } else {
            throw new Error(data.error || "Błąd");
          }
        } catch (error) {
          console.error("Error:", error);
          loadingOverlay.classList.add("hidden");
          button.disabled = false;
          alert("Wystąpił błąd. Spróbuj ponownie.");
        }
      });
    });
  });
</script>
